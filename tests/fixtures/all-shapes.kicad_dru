(version 1)

# Torture test — exercise as many DRU shapes as possible.
# Targeted at KiCad 9 stable; everything in this file should pass
# *Check Rule Syntax* on a stock KiCad 9 install. Master-only constraints
# live in master-only.kicad_dru.

# 1. Layer-shortcut + simple constraint
(rule "outer_clearance"
    (layer outer)
    (constraint clearance (min 0.25mm)))

# 2. Inner-layer shortcut
(rule "inner_clearance"
    (layer inner)
    (constraint clearance (min 0.15mm)))

# 3. Named layer
(rule front_mechanical_board_edge_clearance
    (layer "F.Courtyard")
    (constraint physical_clearance (min 3mm))
    (condition "B.Layer == 'Edge.Cuts'"))

# 4. Net-class condition + clearance
(rule HV
    (condition "A.hasNetclass('HV')")
    (constraint clearance (min 1.5mm)))

# 5. Multiple constraints in one rule (BGA neckdown)
(rule "BGA neckdown"
    (constraint track_width (min 0.2mm) (opt 0.25mm))
    (constraint clearance (min 0.05mm) (opt 0.08mm))
    (condition "A.intersectsCourtyard('U3')"))

# 6. Disallow — v9-compatible (only the 10 v9 keywords)
(rule "no vias or buried vias here"
    (constraint disallow via buried_via)
    (condition "A.intersectsArea('NoVias')"))

# 7. Length with from-to
(rule "DDR_DQ0 length"
    (condition "A.fromTo('U1-A1', 'U2-B1')")
    (constraint length (max 50mm)))

# 8. Skew within diff pair
(rule "USB skew"
    (constraint skew (max 0.05mm) (within_diff_pairs))
    (condition "A.inDiffPair('USB')"))

# 9. Assertion with property comparison
(rule "no soldermask overrides"
    (constraint assertion "A.Soldermask_Margin_Override == 0mm")
    (condition "A.Type == 'Pad'"))

# 10. Severity override
(rule "Allow connector silk on edge"
    (constraint silk_clearance)
    (severity ignore)
    (condition "A.memberOfFootprint('J*') && B.Layer=='Edge.Cuts'"))

# 11. Zone connection forced
(rule "thermal-only on power pads"
    (constraint zone_connection thermal_reliefs)
    (condition "A.NetClass == 'PWR'"))

# 12. Min resolved spokes
(rule "spoke count"
    (constraint min_resolved_spokes 2)
    (condition "A.NetClass == 'PWR'"))

# 13. Track angle / segment (KiCad 9+). track_angle is unit-less in
# the parser — bare number, interpreted in degrees.
(rule "no acute bends"
    (constraint track_angle (min 90)))

(rule "min segment length"
    (constraint track_segment_length (min 0.5mm)))

# 14. Creepage (KiCad 9+)
(rule "HV creepage"
    (constraint creepage (min 1.5mm))
    (condition "A.NetClass == 'HV'"))

# 15. Connection width (KiCad 7+)
(rule "min connection width"
    (constraint connection_width (min 0.2mm)))

# 16. Arithmetic in constraint value
(rule "clearance-with-arith"
    (constraint clearance (min 0.5mm + 0.1mm)))

# 17. Deprecated constraint — should colour as deprecated
(rule "old-style"
    (constraint mechanical_clearance (min 0.5mm)))

# 18. Quoted enum value with literal space
(rule "no text boxes here"
    (constraint disallow text)
    (condition "A.Type == 'Text Box'"))

# 19. Text-variable arg pattern (special-cased — not preprocessed)
(rule "memberOfFootprint by class"
    (constraint clearance (min 0.4mm))
    (condition "A.memberOfFootprint('${Class:HighCurrent}')"))

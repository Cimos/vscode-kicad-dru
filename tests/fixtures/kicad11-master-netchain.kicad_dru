(version 1)

# KiCad 11 / master net-chain / high-speed constraints and functions.
# These are NOT in KiCad 10.0.0 stable (a 10.0.0 DRC parser rejects them) —
# verified absent from the 10.0.0 tag, present on master (2026-06-20).
# Grammar-only coverage: highlighted but deliberately kept OUT of the snippet set.

(rule "net-chain length budget"
    (condition "A.inNetChain('DDR_CMD')")
    (constraint net_chain_length (min 10mm) (max 25mm)))

(rule "net-chain time budget"
    (condition "A.hasNetChain()")
    (constraint net_chain_length (max 150ps)))

(rule "stub length limit"
    (condition "A.inNetChainClass('HS')")
    (constraint stub_length (max 0.5mm)))

(rule "return path"
    (condition "A.NetClass == 'HS'")
    (constraint return_path (layer "B.Cu") (net "GND")))

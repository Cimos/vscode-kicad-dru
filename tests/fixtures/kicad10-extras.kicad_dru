(version 1)

# KiCad 10 stable "extras" — beyond the KiCad 9 baseline.
# solder_mask_*, solder_paste_*, via_dangling, bridged_mask and the
# through_via / blind_via disallow keywords were master-only relative to
# KiCad 9 but shipped in KiCad 10.0.0; verified against the 10.0.0 tag
# (2026-06-20). All of these PASS *Check Rule Syntax* on KiCad 10.

# Disallow — through_via and blind_via (stable in KiCad 10)
(rule "no through-hole or blind vias"
    (constraint disallow through_via blind_via)
    (condition "A.intersectsArea('NoThrough')"))

# via_dangling — flag vias that don't connect or land on only one layer
(rule "flag dangling vias"
    (constraint via_dangling)
    (severity warning))

# solder_mask_expansion — opt mask expansion for pads/shapes/tracks
(rule "default mask expansion"
    (constraint solder_mask_expansion (opt 0.05mm)))

# solder_mask_sliver — minimum sliver width on the soldermask
(rule "no thin mask slivers"
    (constraint solder_mask_sliver (min 0.05mm)))

# solder_paste_abs_margin — absolute paste margin
(rule "BGA paste pull-back (absolute)"
    (constraint solder_paste_abs_margin (opt -0.05mm))
    (condition "A.intersectsCourtyard('U3')"))

# solder_paste_rel_margin — relative paste margin (unitless ratio)
(rule "BGA paste pull-back (relative)"
    (constraint solder_paste_rel_margin (opt -0.1))
    (condition "A.intersectsCourtyard('U4')"))

# bridged_mask — solder-mask bridging between copper, severity-controlled
(rule "allow mask bridges between SOIC pads"
    (constraint bridged_mask)
    (severity ignore)
    (condition "A.memberOfFootprint('U10')"))

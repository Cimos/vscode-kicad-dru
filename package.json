{
  "name": "kicad-dru",
  "displayName": "KiCad Custom Design Rules",
  "description": "Syntax highlighting and snippets for KiCad Custom Design Rules (.kicad_dru) files.",
  "version": "0.0.2",
  "publisher": "cimos",
  "license": "MIT",
  "icon": "images/D1_256.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cimos/vscode-kicad-dru.git"
  },
  "bugs": {
    "url": "https://github.com/Cimos/vscode-kicad-dru/issues"
  },
  "homepage": "https://github.com/Cimos/vscode-kicad-dru#readme",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:kicad-dru"
  ],
  "keywords": [
    "kicad",
    "kicad_dru",
    "design rules",
    "drc",
    "pcb",
    "eda",
    "s-expression"
  ],
  "scripts": {
    "test:snap": "vscode-tmgrammar-snap -s source.kicad-dru -g syntaxes/kicad-dru.tmLanguage.json \"tests/fixtures/*.kicad_dru\"",
    "test:cases": "vscode-tmgrammar-test -g syntaxes/kicad-dru.tmLanguage.json \"tests/cases/*.kicad_dru\"",
    "test": "npm run test:snap && npm run test:cases && npm run test:unit",
    "test:update": "vscode-tmgrammar-snap -s source.kicad-dru -g syntaxes/kicad-dru.tmLanguage.json -u \"tests/fixtures/*.kicad_dru\"",
    "test:unit": "npm run compile && node --test \"tests/unit/**/*.test.mjs\"",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "npm run typecheck && node esbuild.mjs --production",
    "vscode:prepublish": "npm run package"
  },
  "devDependencies": {
    "vscode-tmgrammar-test": "^0.1.3",
    "typescript": "^5.4.0",
    "esbuild": "^0.21.0",
    "@types/vscode": "~1.80.0",
    "@types/node": "^20.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "kicad-dru",
        "aliases": [
          "KiCad Custom Design Rules",
          "kicad-dru"
        ],
        "extensions": [
          ".kicad_dru"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kicad-dru",
        "scopeName": "source.kicad-dru",
        "path": "./syntaxes/kicad-dru.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "kicad-dru",
        "path": "./snippets/kicad-dru.json"
      }
    ]
  }
}

{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "KiCad Custom Design Rules",
  "scopeName": "source.kicad-dru",
  "fileTypes": ["kicad_dru"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#expression" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*#.*$",
      "name": "comment.line.number-sign.kicad-dru"
    },

    "expression": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#version-clause" },
        { "include": "#rule-clause" },
        { "include": "#assertion-constraint" },
        { "include": "#disallow-constraint" },
        { "include": "#zone-connection-constraint" },
        { "include": "#min-resolved-spokes-constraint" },
        { "include": "#return-path-constraint" },
        { "include": "#standard-constraint" },
        { "include": "#deprecated-constraint" },
        { "include": "#condition-clause" },
        { "include": "#layer-clause" },
        { "include": "#severity-clause" },
        { "include": "#min-max-opt-clause" },
        { "include": "#within-diff-pairs" },
        { "include": "#parens" },
        { "include": "#string-double" },
        { "include": "#string-single" },
        { "include": "#number-with-unit" },
        { "include": "#layer-keyword" },
        { "include": "#text-variable" },
        { "include": "#identifier" }
      ]
    },

    "version-clause": {
      "begin": "(\\()\\s*(version)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.version.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.version.kicad-dru",
      "patterns": [
        {
          "match": "\\b\\d+\\b",
          "name": "constant.numeric.integer.kicad-dru"
        }
      ]
    },

    "rule-clause": {
      "begin": "(\\()\\s*(rule)\\b\\s*(?:(\"[^\"]*\")|('[^']*')|([A-Za-z_][A-Za-z0-9_.\\-]*))?",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.rule.kicad-dru" },
        "3": { "name": "entity.name.section.rule.kicad-dru" },
        "4": { "name": "entity.name.section.rule.kicad-dru" },
        "5": { "name": "entity.name.section.rule.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.rule.kicad-dru",
      "patterns": [
        { "include": "#expression" }
      ]
    },

    "condition-clause": {
      "begin": "(\\()\\s*(condition)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.condition.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.condition.kicad-dru",
      "patterns": [
        { "include": "#expression-string-outer-double" },
        { "include": "#expression-string-outer-single" }
      ]
    },

    "assertion-constraint": {
      "begin": "(\\()\\s*(constraint)\\s+(assertion)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.constraint.kicad-dru" },
        "3": { "name": "support.type.constraint.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.constraint.assertion.kicad-dru",
      "patterns": [
        { "include": "#expression-string-outer-double" },
        { "include": "#expression-string-outer-single" }
      ]
    },

    "disallow-constraint": {
      "begin": "(\\()\\s*(constraint)\\s+(disallow)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.constraint.kicad-dru" },
        "3": { "name": "support.type.constraint.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.constraint.disallow.kicad-dru",
      "patterns": [
        {
          "match": "\\b(track|through_via|blind_via|buried_via|micro_via|via|pad|zone|text|graphic|hole|footprint)\\b",
          "name": "constant.language.disallow-category.kicad-dru"
        }
      ]
    },

    "zone-connection-constraint": {
      "begin": "(\\()\\s*(constraint)\\s+(zone_connection)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.constraint.kicad-dru" },
        "3": { "name": "support.type.constraint.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.constraint.zone-connection.kicad-dru",
      "patterns": [
        {
          "match": "\\b(solid|thermal_reliefs|none)\\b",
          "name": "constant.language.zone-connection.kicad-dru"
        }
      ]
    },

    "min-resolved-spokes-constraint": {
      "begin": "(\\()\\s*(constraint)\\s+(min_resolved_spokes)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.constraint.kicad-dru" },
        "3": { "name": "support.type.constraint.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.constraint.min-resolved-spokes.kicad-dru",
      "patterns": [
        {
          "match": "\\b[0-4]\\b",
          "name": "constant.numeric.integer.kicad-dru"
        }
      ]
    },

    "return-path-constraint": {
      "begin": "(\\()\\s*(constraint)\\s+(return_path)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.constraint.kicad-dru" },
        "3": { "name": "support.type.constraint.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.constraint.return-path.kicad-dru",
      "comment": "KiCad 10 net-chain constraint. Takes (layer \"…\") and optional (net \"…\") sub-clauses instead of min/opt/max.",
      "patterns": [
        { "include": "#layer-clause" },
        { "include": "#net-clause" },
        { "include": "#expression" }
      ]
    },

    "net-clause": {
      "begin": "(\\()\\s*(net)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.net.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.net.kicad-dru",
      "patterns": [
        { "include": "#string-double" },
        { "include": "#string-single" },
        { "include": "#text-variable" }
      ]
    },

    "standard-constraint": {
      "begin": "(\\()\\s*(constraint)\\s+(annular_width|bridged_mask|clearance|connection_width|courtyard_clearance|creepage|diff_pair_gap|diff_pair_uncoupled|edge_clearance|hole_clearance|hole_size|hole_to_hole|length|net_chain_length|physical_clearance|physical_hole_clearance|silk_clearance|skew|solder_mask_expansion|solder_mask_sliver|solder_paste_abs_margin|solder_paste_rel_margin|stub_length|text_height|text_thickness|thermal_relief_gap|thermal_spoke_width|track_angle|track_segment_length|track_width|via_count|via_dangling|via_diameter)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.constraint.kicad-dru" },
        "3": { "name": "support.type.constraint.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.constraint.kicad-dru",
      "patterns": [
        { "include": "#expression" }
      ]
    },

    "deprecated-constraint": {
      "begin": "(\\()\\s*(constraint)\\s+(mechanical_clearance|mechanical_hole_clearance|hole)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.constraint.kicad-dru" },
        "3": { "name": "invalid.deprecated.constraint.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.constraint.deprecated.kicad-dru",
      "patterns": [
        { "include": "#expression" }
      ]
    },

    "layer-clause": {
      "begin": "(\\()\\s*(layer)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.layer.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.layer.kicad-dru",
      "patterns": [
        {
          "match": "\\b(outer|inner)\\b",
          "name": "constant.language.layer-shortcut.kicad-dru"
        },
        { "include": "#layer-keyword" },
        { "include": "#layer-quoted-double" },
        { "include": "#layer-quoted-single" }
      ]
    },

    "layer-quoted-double": {
      "comment": "Quoted layer name in a (layer ...) clause. Still a string, but a known canonical layer token inside is highlighted as a layer — KiCad accepts quoted layer names.",
      "begin": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.kicad-dru" } },
      "end": "\"",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.kicad-dru" } },
      "name": "string.quoted.double.kicad-dru",
      "patterns": [
        { "include": "#layer-keyword" }
      ]
    },

    "layer-quoted-single": {
      "comment": "Single-quoted variant of #layer-quoted-double.",
      "begin": "'",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.kicad-dru" } },
      "end": "'",
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.kicad-dru" } },
      "name": "string.quoted.single.kicad-dru",
      "patterns": [
        { "include": "#layer-keyword" }
      ]
    },

    "severity-clause": {
      "begin": "(\\()\\s*(severity)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.control.severity.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.severity.kicad-dru",
      "patterns": [
        {
          "match": "\\b(error|warning|ignore|exclusion)\\b",
          "name": "constant.language.severity.kicad-dru"
        }
      ]
    },

    "min-max-opt-clause": {
      "begin": "(\\()\\s*(min|max|opt)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.other.bound.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.bound.kicad-dru",
      "patterns": [
        { "include": "#number-with-unit" },
        { "include": "#expression-operators-arith" }
      ]
    },

    "within-diff-pairs": {
      "match": "(\\()\\s*(within_diff_pairs)\\s*(\\))",
      "captures": {
        "1": { "name": "punctuation.section.parens.begin.kicad-dru" },
        "2": { "name": "keyword.other.flag.kicad-dru" },
        "3": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.flag.within-diff-pairs.kicad-dru"
    },

    "parens": {
      "begin": "\\(",
      "beginCaptures": {
        "0": { "name": "punctuation.section.parens.begin.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "name": "meta.parens.kicad-dru",
      "patterns": [
        { "include": "#expression" }
      ]
    },

    "string-double": {
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.kicad-dru" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.kicad-dru" }
      },
      "name": "string.quoted.double.kicad-dru"
    },

    "string-single": {
      "begin": "'",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.kicad-dru" }
      },
      "end": "'",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.kicad-dru" }
      },
      "name": "string.quoted.single.kicad-dru"
    },

    "number-with-unit": {
      "patterns": [
        {
          "match": "(?<![A-Za-z_])(-?(?:\\d+\\.\\d+|\\.\\d+|\\d+))(mm|mil|in|deg|fs|ps)\\b",
          "captures": {
            "1": { "name": "constant.numeric.kicad-dru" },
            "2": { "name": "keyword.other.unit.kicad-dru" }
          }
        },
        {
          "match": "(?<![A-Za-z_])-?(?:\\d+\\.\\d+|\\.\\d+|\\d+)\\b",
          "name": "constant.numeric.kicad-dru"
        }
      ]
    },

    "layer-keyword": {
      "match": "\\b(F\\.Cu|B\\.Cu|In(?:[1-9]|[12][0-9]|30)\\.Cu|F\\.Adhes|B\\.Adhes|F\\.Paste|B\\.Paste|F\\.SilkS|B\\.SilkS|F\\.Mask|B\\.Mask|F\\.CrtYd|B\\.CrtYd|F\\.Fab|B\\.Fab|F\\.Courtyard|B\\.Courtyard|Edge\\.Cuts|Margin|Dwgs\\.User|Cmts\\.User|Eco1\\.User|Eco2\\.User|User\\.[1-9])\\b",
      "name": "constant.language.layer.kicad-dru"
    },

    "text-variable": {
      "match": "\\$\\{[^}]+\\}",
      "name": "variable.other.text-variable.kicad-dru"
    },

    "identifier": {
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b",
      "name": "variable.other.kicad-dru"
    },

    "expression-string-outer-double": {
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.kicad-dru" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.kicad-dru" }
      },
      "name": "string.quoted.double.kicad-dru meta.embedded.expression.kicad-dru",
      "contentName": "meta.embedded.expression.kicad-dru",
      "patterns": [
        { "include": "#expression-body-double-outer" }
      ]
    },

    "expression-string-outer-single": {
      "begin": "'",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.kicad-dru" }
      },
      "end": "'",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.kicad-dru" }
      },
      "name": "string.quoted.single.kicad-dru meta.embedded.expression.kicad-dru",
      "contentName": "meta.embedded.expression.kicad-dru",
      "patterns": [
        { "include": "#expression-body-single-outer" }
      ]
    },

    "expression-body-double-outer": {
      "patterns": [
        { "include": "#expression-string-inner-single" },
        { "include": "#expression-paren-double-outer" },
        { "include": "#expression-non-string-patterns" }
      ]
    },

    "expression-body-single-outer": {
      "patterns": [
        { "include": "#expression-string-inner-double" },
        { "include": "#expression-paren-single-outer" },
        { "include": "#expression-non-string-patterns" }
      ]
    },

    "expression-non-string-patterns": {
      "patterns": [
        { "include": "#expression-text-variable" },
        { "include": "#expression-accessor-deprecated-function" },
        { "include": "#expression-accessor-function" },
        { "include": "#expression-accessor-property" },
        { "include": "#expression-accessor" },
        { "include": "#expression-null-literal" },
        { "include": "#expression-operators-comparison" },
        { "include": "#expression-operators-logical" },
        { "include": "#expression-operators-arith" },
        { "include": "#expression-number-with-unit" },
        { "include": "#expression-identifier" }
      ]
    },

    "expression-string-inner-single": {
      "begin": "'",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.kicad-dru" }
      },
      "end": "'",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.kicad-dru" }
      },
      "name": "string.quoted.single.kicad-dru"
    },

    "expression-string-inner-double": {
      "begin": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.kicad-dru" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.kicad-dru" }
      },
      "name": "string.quoted.double.kicad-dru"
    },

    "expression-paren-double-outer": {
      "begin": "\\(",
      "beginCaptures": {
        "0": { "name": "punctuation.section.parens.begin.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "patterns": [
        { "include": "#expression-body-double-outer" }
      ]
    },

    "expression-paren-single-outer": {
      "begin": "\\(",
      "beginCaptures": {
        "0": { "name": "punctuation.section.parens.begin.kicad-dru" }
      },
      "end": "\\)",
      "endCaptures": {
        "0": { "name": "punctuation.section.parens.end.kicad-dru" }
      },
      "patterns": [
        { "include": "#expression-body-single-outer" }
      ]
    },

    "expression-text-variable": {
      "match": "\\$\\{[^}]+\\}",
      "name": "variable.other.text-variable.kicad-dru"
    },

    "expression-accessor-deprecated-function": {
      "comment": "Receiver-bound DEPRECATED function call (insideArea/insideCourtyard/insideFrontCourtyard/insideBackCourtyard/memberOf). Matched BEFORE expression-accessor-function so the name scopes invalid.deprecated rather than support.function. memberOf uses a negative lookahead so it does NOT swallow memberOfGroup/memberOfFootprint/memberOfSheet/memberOfSheetOrChildren.",
      "match": "(\\bAB\\b|\\b[ABL]\\b)(\\.)(insideArea|insideCourtyard|insideFrontCourtyard|insideBackCourtyard|memberOf(?![A-Za-z0-9_]))(?=\\s*\\()",
      "captures": {
        "1": { "name": "variable.language.accessor.kicad-dru" },
        "2": { "name": "punctuation.accessor.kicad-dru" },
        "3": { "name": "invalid.deprecated.function.kicad-dru" }
      }
    },

    "expression-accessor-function": {
      "comment": "Receiver-bound function call, e.g. A.intersectsArea('x'). Matched before the property rule so a call gets support.function rather than support.variable.property. Any identifier after the accessor followed by '(' is treated as a method.",
      "match": "(\\bAB\\b|\\b[ABL]\\b)(\\.)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "variable.language.accessor.kicad-dru" },
        "2": { "name": "punctuation.accessor.kicad-dru" },
        "3": { "name": "support.function.kicad-dru" }
      }
    },

    "expression-accessor-property": {
      "match": "(\\bAB\\b|\\b[ABL]\\b)(\\.)([A-Za-z_][A-Za-z0-9_\\-%]*)",
      "captures": {
        "1": { "name": "variable.language.accessor.kicad-dru" },
        "2": { "name": "punctuation.accessor.kicad-dru" },
        "3": { "name": "support.variable.property.kicad-dru" }
      }
    },

    "expression-accessor": {
      "match": "\\b(AB|A|B|L)\\b",
      "name": "variable.language.accessor.kicad-dru"
    },

    "expression-null-literal": {
      "match": "\\bnull\\b",
      "name": "constant.language.null.kicad-dru"
    },

    "expression-operators-comparison": {
      "match": "==|!=|<=|>=|<|>",
      "name": "keyword.operator.comparison.kicad-dru"
    },

    "expression-operators-logical": {
      "match": "&&|\\|\\||!(?!=)",
      "name": "keyword.operator.logical.kicad-dru"
    },

    "expression-operators-arith": {
      "match": "[+\\-*/]",
      "name": "keyword.operator.arithmetic.kicad-dru"
    },

    "expression-number-with-unit": {
      "patterns": [
        {
          "match": "(?<![A-Za-z_])(-?(?:\\d+\\.\\d+|\\.\\d+|\\d+))(mm|mil|in|deg|fs|ps)\\b",
          "captures": {
            "1": { "name": "constant.numeric.kicad-dru" },
            "2": { "name": "keyword.other.unit.kicad-dru" }
          }
        },
        {
          "match": "(?<![A-Za-z_])-?(?:\\d+\\.\\d+|\\.\\d+|\\d+)\\b",
          "name": "constant.numeric.kicad-dru"
        }
